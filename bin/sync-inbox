#!/usr/bin/env bash
# Stages whatever's in content/schedule-inbox/, commits, pushes.
# The Process-schedule-inbox GitHub Action then processes the files within ~30s.
#
# Usage: from the bearagent repo root, run `./bin/sync-inbox`.
#        Or alias: `alias bearagent-sync='~/bearagent/bin/sync-inbox'`.

set -euo pipefail

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
REPO_DIR="$( dirname "$SCRIPT_DIR" )"
cd "$REPO_DIR"

git add content/schedule-inbox

if git diff --staged --quiet; then
  echo "Inbox is empty (nothing new to push)."
  exit 0
fi

FILES=$(git diff --staged --name-only)
COUNT=$(echo "$FILES" | wc -l | tr -d ' ')

echo "Pushing ${COUNT} inbox change(s):"
echo "$FILES" | sed 's/^/  /'
echo ""

git commit -m "inbox: drop ${COUNT} file(s)"
git push

echo ""
echo "✓ Pushed."
echo "  Action: https://github.com/jaelrolli-coder/bearagent/actions/workflows/process-inbox.yml"
